/* 吃什么页面样式 */

.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.result-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 300rpx;
  margin-bottom: 60rpx;
}

.food-display {
  text-align: center;
  transition: transform 0.1s;
}

.food-display.rolling {
  animation: shake 0.1s infinite;
}

@keyframes shake {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(-5rpx) rotate(-5deg); }
  75% { transform: translateX(5rpx) rotate(5deg); }
}

.food-emoji {
  display: block;
  font-size: 160rpx;
  line-height: 1.2;
  margin-bottom: 20rpx;
}

.food-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
}

.button-section {
  margin-bottom: 40rpx;
}

.btn-roll {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.btn-roll[disabled] {
  opacity: 0.7;
}

.tips {
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  opacity: 0.6;
}